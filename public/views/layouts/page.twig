<!DOCTYPE html>
<html lang="pl">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="shortcut icon" href="data:image/x-icon;" type="image/x-icon">
  <link href="https://fonts.googleapis.com/css?family=Nunito:200,600" rel="stylesheet">
  <title>{{ page.title }}</title>
  {{ css|raw }}
  <script>
    document.url = '{{ url() }}';
  </script>
</head>
<body>
{% import 'components/form.twig' as form %}
{% import 'components/button.twig' as button %}
<section class="grid">

  <aside class="left-panel d-flex">
    <h1 class="title__headline">Graff PHP</h1>
    <a href="{{ url() }}">About</a>
    <a href="{{ url() }}">Install</a>

    <a href="#" class="has__parent">Build first application</a>
    <div class="parent">
      <a href="{{ url('/clients/add') }}">nowy</a>
      <a href="{{ url('/clients') }}">Lista</a>
    </div>

  </aside>

  <main class="right-panel">
    {% include 'layouts/inc/alert.twig' %}
    {% block content %}
    {% endblock %}
  </main>
</section>

{% include 'components/modal.twig' %}
<script type="module" src="{{ base('/public/js/components/main.js') }}"></script>
{{ js|raw }}
